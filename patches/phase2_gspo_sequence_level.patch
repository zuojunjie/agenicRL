# Phase 2 GSPO sequence-level ratio patch
#
# 依赖：phase2_dapo_clip_higher.patch 必须先 apply（提供 cliprange_high 形参 + 调用站点）
#
# 改动：core_algos.compute_policy_loss 加 loss_agg_mode 参数：
#   - 'token'    : token-level ratio + token-level clip（GRPO/DAPO 默认）
#   - 'sequence' : sequence-level ratio + sequence-level clip（GSPO 论文 Eq. 6-7）
#
# 数学差异（关键 5 行）：
#
#   GRPO/DAPO (token-level)：
#     ratio_{i,t} = exp(log_pi_new(y_{i,t}) - log_pi_old(y_{i,t}))
#     loss = mean over (i,t) of clip(ratio_{i,t}) * adv_{i,t}
#
#   GSPO (sequence-level)：
#     mean_kl_diff_i = mean_t (log_pi_new(t) - log_pi_old(t))  # 长度归一化
#     ratio_i = exp(mean_kl_diff_i)
#     loss = mean over i of clip(ratio_i) * adv_i
#
# 应用方式（云端，先 DAPO 再 GSPO）：
#   cd /root/autodl-tmp/external/Search-R1
#   patch -p1 < /root/autodl-tmp/agenicRL/patches/phase2_dapo_clip_higher.patch
#   patch -p1 < /root/autodl-tmp/agenicRL/patches/phase2_gspo_sequence_level.patch
#
# 回滚顺序相反：先 GSPO -R 再 DAPO -R

--- a/verl/trainer/ppo/core_algos.py
+++ b/verl/trainer/ppo/core_algos.py
@@ -160,7 +160,7 @@ def compute_rewards(token_level_scores, old_log_prob, ref_log_prob, kl_ratio):
     return token_level_scores - kl * kl_ratio


-def compute_policy_loss(old_log_prob, log_prob, advantages, eos_mask, cliprange, cliprange_high=None):
+def compute_policy_loss(old_log_prob, log_prob, advantages, eos_mask, cliprange, cliprange_high=None, loss_agg_mode='token'):
     """Adapted from https://github.com/huggingface/trl/blob/main/trl/trainer/ppo_trainer.py#L1122

     Args:
@@ -177,6 +177,10 @@ def compute_policy_loss(old_log_prob, log_prob, advantages, eos_mask, cliprange,
         cliprange_high: (float, optional)
             DAPO clip-higher: asymmetric upper bound for ratio clipping.
             If None, falls back to symmetric ``cliprange`` (vanilla PPO/GRPO).
+        loss_agg_mode: ('token' | 'sequence')
+            'token' (default): token-level ratio & clip (GRPO/DAPO).
+            'sequence': GSPO — length-normalized sequence-level ratio & clip
+            (https://arxiv.org/abs/2507.18071, Eq. 6-7).

     Returns:
         pg_loss: `a scalar torch.Tensor`
@@ -187,15 +191,32 @@ def compute_policy_loss(old_log_prob, log_prob, advantages, eos_mask, cliprange,
     """
     if cliprange_high is None:
         cliprange_high = cliprange
-    negative_approx_kl = log_prob - old_log_prob
-    ratio = torch.exp(negative_approx_kl)
-    ppo_kl = verl_F.masked_mean(-negative_approx_kl, eos_mask)
-
-    pg_losses = -advantages * ratio
-    pg_losses2 = -advantages * torch.clamp(ratio, 1.0 - cliprange, 1.0 + cliprange_high)
-
-    pg_loss = verl_F.masked_mean(torch.max(pg_losses, pg_losses2), eos_mask)
-    pg_clipfrac = verl_F.masked_mean(torch.gt(pg_losses2, pg_losses).float(), eos_mask)
+    log_prob_diff = log_prob - old_log_prob  # (bs, T)
+    ppo_kl = verl_F.masked_mean(-log_prob_diff, eos_mask)
+
+    if loss_agg_mode == 'token':
+        # GRPO/DAPO: token-level ratio + clip
+        ratio = torch.exp(log_prob_diff)  # (bs, T)
+        pg_losses = -advantages * ratio
+        pg_losses2 = -advantages * torch.clamp(ratio, 1.0 - cliprange, 1.0 + cliprange_high)
+        pg_loss = verl_F.masked_mean(torch.max(pg_losses, pg_losses2), eos_mask)
+        pg_clipfrac = verl_F.masked_mean(torch.gt(pg_losses2, pg_losses).float(), eos_mask)
+    elif loss_agg_mode == 'sequence':
+        # GSPO: length-normalized sequence-level ratio + sequence-level clip
+        seq_len = eos_mask.sum(dim=-1).clamp_min(1.0)                  # (bs,)
+        seq_log_prob_diff = (log_prob_diff * eos_mask).sum(dim=-1) / seq_len  # (bs,)
+        ratio = torch.exp(seq_log_prob_diff)                           # (bs,)
+        # advantages 也按序列归一化（GRPO 中每个 token 共享同一 advantage，所以等价于取一个）
+        seq_adv = (advantages * eos_mask).sum(dim=-1) / seq_len        # (bs,)
+        pg_losses = -seq_adv * ratio
+        pg_losses2 = -seq_adv * torch.clamp(ratio, 1.0 - cliprange, 1.0 + cliprange_high)
+        pg_loss = torch.mean(torch.max(pg_losses, pg_losses2))
+        pg_clipfrac = torch.mean(torch.gt(pg_losses2, pg_losses).float())
+    else:
+        raise ValueError(f"Unknown loss_agg_mode: {loss_agg_mode}; expect 'token' or 'sequence'")
+
     return pg_loss, pg_clipfrac, ppo_kl


